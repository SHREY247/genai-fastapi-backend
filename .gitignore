# -------------------------------------------------------
# .gitignore — GenAI FastAPI Backend
# -------------------------------------------------------

# Environment variables (NEVER commit secrets)
.env

# Python bytecode
__pycache__/
**__pycache__/
*.pyc
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Archives and build artifacts
*.zip

# Session walkthrough and script files (instructor-only content)
SESSION_*_SCRIPT.md
SESSION_*_WALKTHROUGH.md
WALKTHROUGH.md
*_WALKTHROUGH.md
